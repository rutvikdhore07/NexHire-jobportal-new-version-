# ── DATABASE (Supabase PostgreSQL) ─────────────────────────────────────
# Get these from Supabase → your project → Settings → Database → Connection string
DB_URL=jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# ── DATABASE (Local PostgreSQL) ────────────────────────────────────────
# DB_URL=jdbc:postgresql://localhost:5432/nexhire?sslmode=disable
# DB_USER=postgres
# DB_PASSWORD=password

# ── JWT ────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=nexhire-super-secret-jwt-key-2024-do-not-change-this-ever-ok

# ── CORS ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── PORT ───────────────────────────────────────────────────────────────
PORT=8080
